              "raw": "{\n  \"event_type\": \"summary_viewed\",\n  \"event_category\": \"documents\",\n  \"event_data\": {},\n  \"session_id\": \"postman-session\",\n  \"success\": true\n}"
            },
            "url": "{{baseUrl}}/analytics/events"
          }
        },
        {
          "name": "Get Analytics Settings",
