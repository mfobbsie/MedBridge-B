            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preferred_language\": \"en\",\n  \"notification_enabled\": true\n}"
            },
            "url": "{{baseUrl}}/analytics/settings"
          }
        },
        {
          "name": "Patient Dashboard",
          "request": {
