                  "    pm.collectionVariables.set('followup_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"what\": \"Schedule follow-up blood test\",\n  \"when_text\": \"Within 2 weeks\",\n  \"due_date\": \"2026-07-15\"\n}"
            },
            "url": "{{baseUrl}}/documents/{{document_id}}/follow-ups"
          }
        },
        {
          "name": "Update Follow-up",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completed\": true\n}"
            },
            "url": "{{baseUrl}}/follow-ups/{{followup_id}}"
          }
        },
        {
          "name": "Complete Follow-up",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/follow-ups/{{followup_id}}/complete"
          }
        },
        {
          "name": "Delete Follow-up",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/follow-ups/{{followup_id}}"
          }
        }
      ]
    },
    {
      "name": "Providers",
      "item": [
        {
          "name": "List Providers",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Add Provider",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('provider_id', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Sarah Chen\",\n  \"specialty\": \"Cardiology\",\n  \"phone\": \"555-123-4567\",\n  \"address\": \"123 Medical Center Dr\"\n}"
            },
            "url": "{{baseUrl}}/providers"
          }
        },
        {
          "name": "Update Provider",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"555-999-0000\"\n}"
            },
            "url": "{{baseUrl}}/providers/{{provider_id}}"
          }
        },
        {
          "name": "Delete Provider",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/providers/{{provider_id}}"
          }
        }
      ]
    },
    {
      "name": "Resources (Discover)",
      "item": [
        {
          "name": "List Resources",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/resources?resource_type=article&tag=diabetes",
              "host": ["{{baseUrl}}"],
              "path": ["resources"],
              "query": [
                { "key": "resource_type", "value": "article", "disabled": true },
                { "key": "tag", "value": "diabetes", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Resource",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/resources/{{resource_id}}"
          }
        }
      ]
    },
    {
      "name": "Health Scores",
      "item": [
        {
          "name": "List Health Scores",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health-scores"
          }
        }
      ]
    },
    {
      "name": "User Settings",
      "item": [
        {
          "name": "Get User Settings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user-settings/?user_id={{user_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["user-settings", ""],
              "query": [{ "key": "user_id", "value": "{{user_id}}" }]
            }
          }
        },
        {
          "name": "Update User Settings",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enable_reminders\": true,\n  \"allow_trusted_contacts\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user-settings/?user_id={{user_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["user-settings", ""],
              "query": [{ "key": "user_id", "value": "{{user_id}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"summary_id\": \"{{summary_id}}\",\n  \"rating\": 5,\n  \"feedback_text\": \"Very helpful summary\"\n}"
            },
            "url": "{{baseUrl}}/analytics/feedback"
          }
        },
        {
          "name": "Log Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
