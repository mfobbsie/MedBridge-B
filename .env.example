# Copy this to .env and fill in your values
# Ask Kathy for the Supabase credentials
# NEVER commit your .env file

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Groq AI
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
# Vision model for image OCR / prescription scan (must be available on your Groq account)
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# Epic FHIR (for SMART on FHIR OAuth)
EPIC_CLIENT_ID=your-non-production-client-id-here
FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
REDIRECT_URI=http://localhost:8000/callback

# CORS — comma-separated frontend origins (must match your dev server URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
